# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_bot_token_here

# Google Gemini API Key (from https://aistudio.google.com/)
# Used for image recognition (receipts)
GOOGLE_AI_STUDIO_KEY=your_gemini_key_here

# OpenRouter API Key (from https://openrouter.ai/)
# Used for SMS text parsing (free models available)
OPENROUTER_API_KEY=your_openrouter_key_here

# Google Sheets Config
GOOGLE_SHEET_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/edit
GOOGLE_SERVICE_ACCOUNT_FILE=credentials.json

# Render.com Config (for production deployment)
RENDER_DOMAIN=your-service.onrender.com
WEBHOOK_SECRET=generate_random_32_char_string

# PythonAnywhere Config (legacy, optional)
PYTHONANYWHERE_USERNAME=your_username
